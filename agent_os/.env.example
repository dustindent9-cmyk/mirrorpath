# Dallas — Agent OS environment variables
# Copy this file to .env and fill in your keys:
#   cp .env.example .env

# ── Core LLM providers ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# ── Browser automation ────────────────────────────────────────────────────────
BROWSERBASE_API_KEY=your_browserbase_api_key_here
BROWSERBASE_PROJECT_ID=your_browserbase_project_id_here

# ── Self-modification ─────────────────────────────────────────────────────────
# Allow Dallas to edit its own source code at your command (disabled by default)
DALLAS_SELF_MODIFY=false

# ── MLS / Bridge Interactive ──────────────────────────────────────────────────
# Get your key at https://bridgedataoutput.com
BRIDGE_API_KEY=your_bridge_api_key_here
BRIDGE_DATASET=actris          # e.g. actris (Austin), bright, mred, etc.

# ── Zillow ────────────────────────────────────────────────────────────────────
# Legacy Web Services ID (fallback; register at https://www.zillow.com/howzillow/zestimate.htm)
ZILLOW_ZWSID=your_zillow_zwsid_here

# Zillow Tech Connect OAuth2 (for reporting/leads; apply at https://www.zillow.com/tech-connect/)
ZILLOW_CLIENT_ID=your_zillow_client_id_here
ZILLOW_CLIENT_SECRET=your_zillow_client_secret_here
ZILLOW_REFRESH_TOKEN=your_zillow_refresh_token_here
