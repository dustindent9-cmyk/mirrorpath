{
  "manifest_version": 3,
  "name": "Dallas Copilot",
  "short_name": "Dallas",
  "description": "Your personal AI copilot powered by Dallas — chat instantly from any tab.",
  "version": "1.0.0",

  "action": {
    "default_popup": "popup.html",
    "default_title": "Dallas Copilot",
    "default_icon": {
      "16":  "icons/icon-16.png",
      "48":  "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  },

  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default":  "Alt+D",
        "mac":      "Alt+D"
      },
      "description": "Open Dallas Copilot"
    },
    "new-chat": {
      "suggested_key": {
        "default": "Alt+Shift+D",
        "mac":     "Alt+Shift+D"
      },
      "description": "Start a new Dallas chat"
    }
  },

  "permissions": ["storage"],

  "icons": {
    "16":  "icons/icon-16.png",
    "48":  "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
